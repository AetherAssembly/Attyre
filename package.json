{
  "name": "attyre",
  "version": "4.0.0",
  "description": "Smart wardrobe manager with weather-based suggestions, planning tools, and local-first privacy",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "vite build && electron-builder",
    "lint:css": "bash scripts/lint-css-classes.sh",
    "test": "node --test js/**/*.test.js"
  },
  "keywords": [
    "wardrobe",
    "outfit",
    "weather",
    "planner",
    "fashion",
    "pwa"
  ],
  "author": {
    "name": "AetherAssembly",
    "email": "contact@aetherassembly.org"
  },
  "license": "AGPL-3.0",
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  },
  "overrides": {
    "tar": "^7.5.16",
    "shell-quote": "^1.8.4"
  },
  "allowScripts": {
    "electron@39.8.5": true
  }
}
